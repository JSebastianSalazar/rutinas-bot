# =========================================================
#  PROVEEDORES DE IA
# =========================================================

# ---- TEXTO (el plan) ----
# 'groq' = GRATIS (recomendado) | 'openai' = de pago
AI_TEXT_PROVIDER=groq

# Si usas Groq (gratis, saca tu key en https://console.groq.com/keys):
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Si usas OpenAI en su lugar (requiere saldo):
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini

# ---- IMAGENES ----
# 'pollinations' = GRATIS sin key (recomendado) | 'openai' = de pago | 'none' = sin imagenes
IMAGE_PROVIDER=pollinations
# Solo si IMAGE_PROVIDER=openai:
OPENAI_IMAGE_MODEL=gpt-image-1

# =========================================================
#  CORREO (SMTP)
# =========================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Rutinas Bot <no-reply@tudominio.com>
EMAIL_TO_MAN=
EMAIL_TO_WOMAN=

# =========================================================
#  PROGRAMACION
# =========================================================
CRON_TIME=0 7 * * *
TIMEZONE=Europe/Madrid

# =========================================================
#  SERVIDOR
# =========================================================
PORT=3000
# URL publica del servicio (sin barra final). Solo se usa si IMAGE_PROVIDER=openai
# (las imagenes de Pollinations ya traen su propia URL publica).
PUBLIC_BASE_URL=http://localhost:3000

# Token para disparar el job manualmente con POST /run?token=...
RUN_TOKEN=

# Dias de historial para no repetir comidas
HISTORY_LOOKBACK_DAYS=5

# Email para avisos si el job diario falla (opcional)
ALERT_EMAIL=
