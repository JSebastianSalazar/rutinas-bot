# ---- OpenAI ----
OPENAI_API_KEY=
# Modelo de texto (barato y suficiente para el plan)
OPENAI_TEXT_MODEL=gpt-4o-mini
# Modelo de imagenes
OPENAI_IMAGE_MODEL=gpt-image-1

# ---- SMTP (envio de correo) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Rutinas Bot <no-reply@tudominio.com>
EMAIL_TO_MAN=
EMAIL_TO_WOMAN=

# ---- Programacion ----
# 07:00 todos los dias
CRON_TIME=0 7 * * *
TIMEZONE=Europe/Madrid

# ---- Servidor / imagenes ----
PORT=3000
# URL publica del servicio (sin barra final). En Railway/Render es la URL del deploy.
# Las imagenes generadas se sirven en PUBLIC_BASE_URL/images/...
PUBLIC_BASE_URL=http://localhost:3000

# ---- Flags ----
# Genera imagenes IA cada dia (coste por imagen). Pon false para desactivar.
ENABLE_AI_IMAGES=true
# Numero maximo de planes recientes a recordar para no repetir comidas
HISTORY_LOOKBACK_DAYS=5

# ---- Alertas (opcional) ----
# Si falla la generacion/envio diario, avisa a este correo. Vacio = no avisar.
ALERT_EMAIL=
