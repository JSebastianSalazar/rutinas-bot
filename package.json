{
  "name": "rutinas-bot",
  "version": "1.0.0",
  "description": "Envia un email diario automatizado con plan de alimentacion y ejercicio para una pareja (uno de ellos en lactancia/postparto).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "send:test": "node scripts/sendTest.js",
    "preview": "node scripts/preview.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "openai": "^4.56.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  }
}
